{
  "name": "proxpanel-server",
  "version": "2.0.0",
  "description": "Commercial-grade multi-protocol proxy management panel",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/master/index.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/master/index.js",
    "start:worker": "node dist/worker/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "swagger:gen": "tsx src/swagger.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "prom-client": "^15.1.3",
    "telegraf": "^4.16.3",
    "uuid": "^10.0.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "prisma": "^6.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
