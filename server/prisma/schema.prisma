generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// MULTI-TENANCY & ROLES
// ──────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  email         String?   @unique
  password      String
  role          UserRole  @default(ADMIN)
  resellerId    String?
  reseller      Reseller? @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  language      String    @default("en")
  lastLoginAt   DateTime?
  lastLoginIp   String?
  banned        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  auditLogs     AuditLog[]
  sessions      UserSession[]
  apiKeys       ApiKey[]
}

model UserSession {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token         String    @unique
  ip            String?
  userAgent     String?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  @@index([userId])
}

model ApiKey {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key           String    @unique
  name          String
  permissions   Json      @default("[]")
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  createdAt     DateTime  @default(now())
  @@index([userId])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  RESELLER
  OPERATOR
}

// ──────────────────────────────────────────────
// RESELLERS & MULTI-TENANCY
// ──────────────────────────────────────────────

model Reseller {
  id            String    @id @default(uuid())
  name          String
  contactEmail  String?
  contactTelegram String?
  maxClients    Int       @default(100)
  maxNodes      Int       @default(5)
  trafficLimit  BigInt    @default(107374182400) // 100GB
  usedTraffic   BigInt    @default(0)
  balance       Decimal   @default(0) @db.Decimal(12, 2)
  whiteLabel    Json?     // { logo, primaryColor, companyName }
  active        Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users         User[]
  clients       Client[]

  @@index([active])
}

// ──────────────────────────────────────────────
// PLANS & BILLING
// ──────────────────────────────────────────────

enum PlanType {
  USER
  RESELLER
}

model Plan {
  id            String    @id @default(uuid())
  name          String
  description   String?
  type          PlanType  @default(USER)
  price         Decimal   @default(0) @db.Decimal(10, 2)
  currency      String    @default("USD")
  duration      Int       @default(30)     // days
  trafficLimit  BigInt    @default(0)       // bytes, 0 = unlimited
  maxClients    Int?                        // for RESELLER plans
  maxSpeed      Int?                        // Mbps, null = unlimited
  protocols     Json      @default("[]")   // allowed protocols
  sortOrder     Int       @default(0)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([type, active])
  @@index([sortOrder])
}

// ──────────────────────────────────────────────
// CLIENTS
// ──────────────────────────────────────────────


model Client {
  id            String    @id @default(uuid())
  uuid          String    @unique @default(uuid())
  username      String
  email         String?
  password      String
  trafficLimit  BigInt    @default(0)
  usedTraffic   BigInt    @default(0)
  uploadTraffic BigInt    @default(0)
  downloadTraffic BigInt  @default(0)
  expireAt      DateTime?
  banned        Boolean   @default(false)
  note          String?
  telegramId    BigInt?   @unique
  subId         String    @unique @default(uuid())
  subToken      String    @unique @default(uuid())
  protocols     Json      @default("[\"VLESS\",\"HYSTERIA2\"]")
  lastActiveAt  DateTime?
  lastLoginIp   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  resellerId    String?
  reseller      Reseller? @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  trafficLogs   TrafficLog[]
  inbounds      ClientInbound[]
  settings      ClientSetting?

  @@unique([resellerId, username])
  @@index([subToken])
  @@index([expireAt, banned])
  @@index([resellerId])
}

model ClientSetting {
  id            String    @id @default(uuid())
  clientId      String    @unique
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subFormat     SubFormat @default(BASE64)
  autoUpdate    Boolean   @default(true)
  customSni     String?
  settings      Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum SubFormat {
  BASE64
  JSON
  CLASH
  SINGBOX
  ORIGINAL
}

// ──────────────────────────────────────────────
// NODES & INFRASTRUCTURE
// ──────────────────────────────────────────────

model Node {
  id            String    @id @default(uuid())
  name          String
  host          String
  port          Int       @default(443)
  apiPort       Int       @default(2087)
  secret        String
  country       String?
  city          String?
  isp           String?
  status        NodeStatus @default(OFFLINE)
  lastCheckAt   DateTime?
  lastPingMs    Int?
  version       String?
  cpuUsage      Float?
  memUsage      Float?
  netUpload     BigInt    @default(0)
  netDownload   BigInt    @default(0)
  xrayVersion   String?
  singboxVersion String?
  features      Json      @default("{}")
  tags          String[]
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  inbounds      Inbound[]
  trafficLogs   TrafficLog[]
  nodeMetrics   NodeMetric[]

  @@index([status, active])
}

enum NodeStatus {
  ONLINE
  OFFLINE
  ERROR
  MAINTENANCE
}

model NodeMetric {
  id            String    @id @default(uuid())
  nodeId        String
  node          Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  cpuUsage      Float?
  memUsage      Float?
  netUpload     BigInt    @default(0)
  netDownload   BigInt    @default(0)
  connections   Int       @default(0)
  uptime        Int       @default(0) // seconds
  recordedAt    DateTime  @default(now())
  @@index([nodeId, recordedAt])
}

// ──────────────────────────────────────────────
// INBOUNDS & PORT-SHARING
// ──────────────────────────────────────────────

model Inbound {
  id            String    @id @default(uuid())
  nodeId        String
  node          Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  protocol      Protocol
  tag           String
  port          Int
  listen        String    @default("0.0.0.0")
  settings      Json
  stream        Json      @default("{}")
  routing       Json      @default("{}")
  sniffing      Boolean   @default(true)
  remark        String?
  enable        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  portShares    PortShare[]
  clientInbounds ClientInbound[]

  @@unique([nodeId, tag])
  @@index([nodeId, protocol])
}

model PortShare {
  id            String    @id @default(uuid())
  inboundId     String
  inbound       Inbound   @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  protocol      Protocol
  tag           String
  settings      Json      @default("{}")
  stream        Json      @default("{}")
  host          String?   // SNI host for routing
  path          String?   // gRPC path or WS path
  enable        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([inboundId, tag])
  @@index([host])
}

model ClientInbound {
  id            String    @id @default(uuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  inboundId     String
  inbound       Inbound   @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  uuid          String    @default(uuid())
  enable        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@unique([clientId, inboundId])
}

// ──────────────────────────────────────────────
// PROTOCOLS
// ──────────────────────────────────────────────

enum Protocol {
  VLESS
  VMESS
  TROJAN
  SHADOWSOCKS
  HYSTERIA2
  NAIVEPROXY
  MIERU
  TUIC
}

// ──────────────────────────────────────────────
// ROUTING RULES
// ──────────────────────────────────────────────

model RoutingRule {
  id            String    @id @default(uuid())
  name          String
  description   String?
  enabled       Boolean   @default(true)
  priority      Int       @default(0) // Higher = evaluated first

  // Matcher fields (Xray field-rule compatible)
  type          String    @default("field") // "field" or "logical"
  domain        String[]  // domain patterns: ["example.com", "geosite:google", "domain:google.com"]
  ip            String[]  // IP patterns: ["geoip:cn", "192.168.0.0/16"]
  port          String?   // port range: "80,443" or "1000-2000"
  sourcePort    String?   // source port range
  source        String[]  // source IP patterns
  protocol      String[]  // protocols: ["http", "tls", "bittorrent"]
  inboundTag    String[]  // inbound tags to match

  // Action
  outboundTag   String    @default("direct") // "direct", "block", "proxy", or custom outbound tag
  balancerTag   String?   // balancer tag (if using load balancing)

  // Logical rule support
  subRules      Json?     // for type="logical", array of sub-rules

  // Metadata
  nodeScope     String?   // null = global rules, node id = node-specific rules
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([enabled, priority])
  @@index([nodeScope])
}

// ──────────────────────────────────────────────
// TRAFFIC & STATISTICS
// ──────────────────────────────────────────────

model TrafficLog {
  id            String    @id @default(uuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nodeId        String
  node          Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  upload        BigInt    @default(0)
  download      BigInt    @default(0)
  protocol      Protocol?
  inboundTag    String?
  recordAt      DateTime  @default(now())
  @@index([clientId, recordAt])
  @@index([nodeId, recordAt])
  @@index([recordAt])
}

// ──────────────────────────────────────────────
// AUDIT & SECURITY
// ──────────────────────────────────────────────

model AuditLog {
  id            String    @id @default(uuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        String    // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, EXPORT
  resource      String    // user, client, node, inbound, plan, etc.
  resourceId    String?
  details       Json?
  ip            String?
  userAgent     String?
  createdAt     DateTime  @default(now())
  @@index([userId, createdAt])
  @@index([action, resource])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// TELEGRAM BOT
// ──────────────────────────────────────────────

model TelegramUser {
  id            String    @id @default(uuid())
  telegramId    BigInt    @unique
  username      String?
  firstName     String?
  lastName      String?
  language      String    @default("en")
  isSubscribed  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ──────────────────────────────────────────────
// NOTIFICATIONS & MESSAGES
// ──────────────────────────────────────────────

model Notification {
  id            String    @id @default(uuid())
  type          NotificationType
  title         String
  message       String
  targetUserId  String?
  targetResellerId String?
  read          Boolean   @default(false)
  metadata      Json?
  createdAt     DateTime  @default(now())
  @@index([targetUserId, read])
  @@index([createdAt])
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  TRAFFIC_LIMIT
  SUBSCRIPTION_EXPIRED
  NODE_OFFLINE
  PAYMENT_RECEIVED
}

// ──────────────────────────────────────────────
// SETTINGS & CONFIG
// ──────────────────────────────────────────────

model SystemSetting {
  id            String    @id @default(uuid())
  key           String    @unique
  value         Json
  description   String?
  updatedAt     DateTime  @updatedAt
}

model BackupLog {
  id            String    @id @default(uuid())
  type          BackupType
  status        BackupStatus @default(SUCCESS)
  destination   String    // telegram, s3, local
  filePath      String?
  fileSize      BigInt?
  error         String?
  createdAt     DateTime  @default(now())
  @@index([createdAt])
}

enum BackupType {
  DATABASE
  CONFIG
  FULL
}

enum BackupStatus {
  SUCCESS
  FAILED
  IN_PROGRESS
}

// ──────────────────────────────────────────────
// I18N
// ──────────────────────────────────────────────

model Translation {
  id            String    @id @default(uuid())
  locale        String    // en, ru, zh, fa
  key           String    // e.g. "dashboard.title"
  value         String
  @@unique([locale, key])
  @@index([locale])
}
