generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// MULTI-TENANCY & ROLES
// ──────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  email         String?   @unique
  password      String
  role          UserRole  @default(ADMIN)
  resellerId    String?
  reseller      Reseller? @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  language      String    @default("en")
  lastLoginAt   DateTime?
  lastLoginIp   String?
  banned        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  auditLogs     AuditLog[]
  sessions      UserSession[]
  apiKeys       ApiKey[]
}

model UserSession {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token         String    @unique
  ip            String?
  userAgent     String?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  @@index([userId])
}

model ApiKey {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key           String    @unique
  name          String
  permissions   Json      @default("[]")
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  createdAt     DateTime  @default(now())
  @@index([userId])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  RESELLER
  OPERATOR
}

// ──────────────────────────────────────────────
// RESELLERS & MULTI-TENANCY
// ──────────────────────────────────────────────

model Reseller {
  id            String    @id @default(uuid())
  name          String
  contactEmail  String?
  contactTelegram String?
  planId        String?
  plan          Plan?     @relation("ResellerPlanRef", fields: [planId], references: [id], onDelete: SetNull)
  maxClients    Int       @default(100)
  maxNodes      Int       @default(5)
  trafficLimit  BigInt    @default(107374182400) // 100GB
  usedTraffic   BigInt    @default(0)
  balance       Decimal   @default(0) @db.Decimal(12, 2)
  whiteLabel    Json?     // { logo, primaryColor, companyName }
  active        Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users         User[]
  clients       Client[]
  plans         Plan[]     @relation("ResellerPlans")
  invoices      Invoice[]
  subscriptions Subscription[]

  @@index([active])
}

// ──────────────────────────────────────────────
// PLANS & BILLING
// ──────────────────────────────────────────────

model Plan {
  id            String    @id @default(uuid())
  name          String
  description   String?
  type          PlanType  @default(USER)
  price         Decimal   @default(0) @db.Decimal(10, 2)
  currency      String    @default("USD")
  duration      Int       @default(30) // days
  trafficLimit  BigInt    @default(107374182400) // 100GB
  maxClients    Int       @default(10)
  maxSpeed      Int?      // Mbps, null = unlimited
  protocols     Json      @default("[\"VLESS\",\"HYSTERIA2\",\"NAIVEPROXY\",\"MIERU\"]")
  features      Json      @default("{}")
  active        Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  resellerId    String?
  reseller      Reseller? @relation("ResellerPlans", fields: [resellerId], references: [id], onDelete: SetNull)
  resellers     Reseller[] @relation("ResellerPlanRef")
  orders        Order[]
  subscriptions Subscription[]
  invoices      Invoice[]

  @@index([active, type])
}

enum PlanType {
  USER
  RESELLER
}

model Invoice {
  id            String    @id @default(uuid())
  resellerId    String
  reseller      Reseller  @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  planId        String?
  plan          Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  amount        Decimal   @db.Decimal(12, 2)
  currency      String    @default("USD")
  status        InvoiceStatus @default(PENDING)
  paymentMethod String?   // crypto_pay, stripe, telegram_stars
  paymentId     String?   // external payment system ID
  metadata      Json?
  paidAt        DateTime?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([resellerId, status])
  @@index([paymentId])
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

// ──────────────────────────────────────────────
// CLIENTS & SUBSCRIPTIONS
// ──────────────────────────────────────────────

model Client {
  id            String    @id @default(uuid())
  uuid          String    @unique @default(uuid())
  username      String
  email         String?
  password      String
  trafficLimit  BigInt    @default(0)
  usedTraffic   BigInt    @default(0)
  uploadTraffic BigInt    @default(0)
  downloadTraffic BigInt  @default(0)
  expireAt      DateTime?
  banned        Boolean   @default(false)
  note          String?
  telegramId    BigInt?   @unique
  subId         String    @unique @default(uuid())
  subToken      String    @unique @default(uuid())
  protocols     Json      @default("[\"VLESS\",\"HYSTERIA2\"]")
  lastActiveAt  DateTime?
  lastLoginIp   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  resellerId    String?
  reseller      Reseller? @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  trafficLogs   TrafficLog[]
  inbounds      ClientInbound[]
  settings      ClientSetting?
  subscriptions Subscription[]
  orders        Order[]

  @@unique([resellerId, username])
  @@index([subToken])
  @@index([expireAt, banned])
  @@index([resellerId])
}

model ClientSetting {
  id            String    @id @default(uuid())
  clientId      String    @unique
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subFormat     SubFormat @default(BASE64)
  autoUpdate    Boolean   @default(true)
  customSni     String?
  settings      Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum SubFormat {
  BASE64
  JSON
  CLASH
  SINGBOX
  ORIGINAL
}

model Subscription {
  id            String    @id @default(uuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planId        String?
  plan          Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  resellerId    String?
  reseller      Reseller? @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  status        SubscriptionStatus @default(ACTIVE)
  startAt       DateTime  @default(now())
  expireAt      DateTime?
  trafficLimit  BigInt    @default(0)
  usedTraffic   BigInt    @default(0)
  autoRenew     Boolean   @default(false)
  paymentId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([clientId, status])
  @@index([expireAt])
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

model Order {
  id            String    @id @default(uuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planId        String
  plan          Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  amount        Decimal   @db.Decimal(10, 2)
  currency      String    @default("USD")
  status        OrderStatus @default(PENDING)
  paymentMethod String?
  paymentId     String?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([clientId, status])
  @@index([paymentId])
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

// ──────────────────────────────────────────────
// NODES & INFRASTRUCTURE
// ──────────────────────────────────────────────

model Node {
  id            String    @id @default(uuid())
  name          String
  host          String
  port          Int       @default(443)
  apiPort       Int       @default(2087)
  secret        String
  country       String?
  city          String?
  isp           String?
  status        NodeStatus @default(OFFLINE)
  lastCheckAt   DateTime?
  lastPingMs    Int?
  version       String?
  cpuUsage      Float?
  memUsage      Float?
  netUpload     BigInt    @default(0)
  netDownload   BigInt    @default(0)
  xrayVersion   String?
  singboxVersion String?
  features      Json      @default("{}")
  tags          String[]
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  inbounds      Inbound[]
  trafficLogs   TrafficLog[]
  nodeMetrics   NodeMetric[]

  @@index([status, active])
}

enum NodeStatus {
  ONLINE
  OFFLINE
  ERROR
  MAINTENANCE
}

model NodeMetric {
  id            String    @id @default(uuid())
  nodeId        String
  node          Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  cpuUsage      Float?
  memUsage      Float?
  netUpload     BigInt    @default(0)
  netDownload   BigInt    @default(0)
  connections   Int       @default(0)
  uptime        Int       @default(0) // seconds
  recordedAt    DateTime  @default(now())
  @@index([nodeId, recordedAt])
}

// ──────────────────────────────────────────────
// INBOUNDS & PORT-SHARING
// ──────────────────────────────────────────────

model Inbound {
  id            String    @id @default(uuid())
  nodeId        String
  node          Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  protocol      Protocol
  tag           String
  port          Int
  listen        String    @default("0.0.0.0")
  settings      Json
  stream        Json      @default("{}")
  routing       Json      @default("{}")
  sniffing      Boolean   @default(true)
  remark        String?
  enable        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  portShares    PortShare[]
  clientInbounds ClientInbound[]

  @@unique([nodeId, tag])
  @@index([nodeId, protocol])
}

model PortShare {
  id            String    @id @default(uuid())
  inboundId     String
  inbound       Inbound   @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  protocol      Protocol
  tag           String
  settings      Json      @default("{}")
  stream        Json      @default("{}")
  host          String?   // SNI host for routing
  path          String?   // gRPC path or WS path
  enable        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([inboundId, tag])
  @@index([host])
}

model ClientInbound {
  id            String    @id @default(uuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  inboundId     String
  inbound       Inbound   @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  uuid          String    @default(uuid())
  enable        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@unique([clientId, inboundId])
}

// ──────────────────────────────────────────────
// PROTOCOLS
// ──────────────────────────────────────────────

enum Protocol {
  VLESS
  VMESS
  TROJAN
  SHADOWSOCKS
  HYSTERIA2
  NAIVEPROXY
  MIERU
  TUIC
}

// ──────────────────────────────────────────────
// TRAFFIC & STATISTICS
// ──────────────────────────────────────────────

model TrafficLog {
  id            String    @id @default(uuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nodeId        String
  node          Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  upload        BigInt    @default(0)
  download      BigInt    @default(0)
  protocol      Protocol?
  inboundTag    String?
  recordAt      DateTime  @default(now())
  @@index([clientId, recordAt])
  @@index([nodeId, recordAt])
  @@index([recordAt])
}

// ──────────────────────────────────────────────
// AUDIT & SECURITY
// ──────────────────────────────────────────────

model AuditLog {
  id            String    @id @default(uuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        String    // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, EXPORT
  resource      String    // user, client, node, inbound, plan, etc.
  resourceId    String?
  details       Json?
  ip            String?
  userAgent     String?
  createdAt     DateTime  @default(now())
  @@index([userId, createdAt])
  @@index([action, resource])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// TELEGRAM BOT
// ──────────────────────────────────────────────

model TelegramUser {
  id            String    @id @default(uuid())
  telegramId    BigInt    @unique
  username      String?
  firstName     String?
  lastName      String?
  language      String    @default("en")
  isSubscribed  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ──────────────────────────────────────────────
// NOTIFICATIONS & MESSAGES
// ──────────────────────────────────────────────

model Notification {
  id            String    @id @default(uuid())
  type          NotificationType
  title         String
  message       String
  targetUserId  String?
  targetResellerId String?
  read          Boolean   @default(false)
  metadata      Json?
  createdAt     DateTime  @default(now())
  @@index([targetUserId, read])
  @@index([createdAt])
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  TRAFFIC_LIMIT
  SUBSCRIPTION_EXPIRED
  NODE_OFFLINE
  PAYMENT_RECEIVED
}

// ──────────────────────────────────────────────
// SETTINGS & CONFIG
// ──────────────────────────────────────────────

model SystemSetting {
  id            String    @id @default(uuid())
  key           String    @unique
  value         Json
  description   String?
  updatedAt     DateTime  @updatedAt
}

model BackupLog {
  id            String    @id @default(uuid())
  type          BackupType
  status        BackupStatus @default(SUCCESS)
  destination   String    // telegram, s3, local
  filePath      String?
  fileSize      BigInt?
  error         String?
  createdAt     DateTime  @default(now())
  @@index([createdAt])
}

enum BackupType {
  DATABASE
  CONFIG
  FULL
}

enum BackupStatus {
  SUCCESS
  FAILED
  IN_PROGRESS
}

// ──────────────────────────────────────────────
// I18N
// ──────────────────────────────────────────────

model Translation {
  id            String    @id @default(uuid())
  locale        String    // en, ru, zh, fa
  key           String    // e.g. "dashboard.title"
  value         String
  @@unique([locale, key])
  @@index([locale])
}
