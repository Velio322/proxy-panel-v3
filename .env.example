# ProxPanel v3 — Environment Variables
# Copy this file to .env and fill in values

# Database (auto-generated by install.sh)
POSTGRES_PASSWORD=

# Auth (auto-generated by install.sh)
JWT_SECRET=
JWT_EXPIRES_IN=7d
NODE_RPC_SECRET=
ENCRYPTION_KEY=

# URLs
API_URL=https://panel.yourdomain.com
FRONTEND_URL=https://panel.yourdomain.com

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# Billing (optional)
CRYPTOPAY_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Backup (optional)
BACKUP_ENABLED=false
