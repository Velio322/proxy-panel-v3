# ──── ProxPanel Environment Variables ────
# Copy to .env and configure

# Database
POSTGRES_USER=proxpanel
POSTGRES_PASSWORD=change-me-in-production

# JWT
JWT_SECRET=change-this-to-a-random-secret-key
JWT_EXPIRES_IN=7d

# Server
API_PORT=3000
API_URL=https://panel.example.com
FRONTEND_URL=https://panel.example.com

# Node communication
NODE_RPC_SECRET=change-this-node-secret

# Encryption
ENCRYPTION_KEY=change-32-char-encryption-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# Billing
CRYPTOPAY_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Backup
BACKUP_ENABLED=false
BACKUP_TELEGRAM_TOKEN=
BACKUP_TELEGRAM_CHAT_ID=

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_UI_PORT=9091
GRAFANA_PORT=3001

# Frontend
FRONTEND_PORT=5173
